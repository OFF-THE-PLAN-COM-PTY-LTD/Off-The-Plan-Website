# Supabase — get from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Mapbox — create token at mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# App — both URLs are used in different places; set to your prod URL on Vercel
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email — Resend integration is NOT yet wired up. Reserved for future
# transactional notifications (enquiries, leads, signup confirmations).
# Leave blank until the integration is implemented.
# RESEND_API_KEY=re_your-resend-api-key

# Stripe — subscription checkout. Use TEST keys/prices for staging, LIVE for
# production (test↔live is a pure env swap; no code changes).
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# One price ID per tier (from your Stripe products, matching the site pricing).
STRIPE_PRICE_AGENCY_LISTING=price_...
STRIPE_PRICE_BUILDERS_PACKAGE=price_...
STRIPE_PRICE_PROMO_FLAG=price_...
STRIPE_PRICE_FEATURED_TIER2=price_...
STRIPE_PRICE_FEATURED_TIER1=price_...
STRIPE_PRICE_HOME_BANNER=price_...

# Cache revalidation webhook — shared secret between the app's /api/revalidate
# route and the Supabase Database Webhooks that call it. Generate a random value
# (e.g. `openssl rand -hex 32`) and set the SAME value here and in each Supabase
# webhook's Authorization header ("Bearer <value>"). See docs/cache-revalidation.md.
REVALIDATE_SECRET=your-long-random-revalidate-secret
